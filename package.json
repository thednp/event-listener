{
  "name": "@thednp/event-listener",
  "author": "thednp",
  "version": "2.0.15",
  "description": "🚅 Modern event listener for efficient web applications based on subscribe-publish pattern.",
  "license": "MIT",
  "homepage": "https://thednp.github.io/event-listener",
  "source": "./src/index.ts",
  "browser": "./dist/index.umd.js",
  "types": "./dist/index.d.cts",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thednp/event-listener.git"
  },
  "bugs": {
    "url": "https://github.com/thednp/event-listener/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "addEventListener",
    "removeEventListener",
    "subscribe",
    "publish",
    "event",
    "listener",
    "javascript-events",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vite --open ./docs/index-dev.html --port 8577",
    "pre-test": "pnpm clean-coverage",
    "prepublishOnly": "pnpm update --latest && pnpm format && pnpm lint && pnpm build",
    "test": "pnpm pre-test && vitest --browser.headless",
    "test-ui": "pnpm pre-test && vitest --browser --ui",
    "clean-coverage": "rm -rf coverage .nyc_output",
    "format": "deno fmt src",
    "lint": "pnpm lint:ts && pnpm check:ts",
    "lint:ts": "deno lint src",
    "fix:ts": "deno lint src --fix",
    "check:ts": "tsc -noEmit",
    "build": "pnpm tsdown && pnpm copy-docs",
    "copy-docs": "cp dist/index.umd.js docs/index.umd.js && cp dist/index.umd.js.map docs/index.umd.js.map"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/browser": "^4.1.1",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-istanbul": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "playwright": "^1.58.2",
    "tsdown": "^0.21.5",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-strip-comments": "^0.0.10",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=16",
    "pnpm": ">=8.6.0"
  }
}
